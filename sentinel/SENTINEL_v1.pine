//@version=6
// =============================================================================
// PROJECT SENTINEL  —  "Smart Execution for Institutional Liquidity"
// Version 4.4  —  ELITE (tidy markers; all inputs live)
// -----------------------------------------------------------------------------
// A modular SMC / institutional-style trading framework for TradingView.
//
// Modules:
//   1. Higher-Timeframe Bias engine        (Daily / 4H / 2H, EMA-trend based)
//   2. Fair Value Gap (FVG) engine          (detection + mitigation lifecycle)
//   3. Liquidity engine                     (sweeps / stop-hunts of swings)
//   4. Market-structure engine              (BOS / CHOCH from swing pivots)
//   5. Session intelligence                 (Asian / London / NY kill zones)
//                                           (PDH/PDL + PWH/PWL liquidity levels)
//   6. Confirmation filters                  (RSI momentum + volume participation)
//   7. Trade manager + backtest             (entry/SL/TP1/TP2, half-and-half mgmt,
//      Arrow-Way exit, W/L · WR% · P/L · Profit Factor · buy/sell split · outcomes)
//   8. Order-block engine                    (demand/supply OBs + mitigation/breakers)
//   9. Overlays (visual only, default OFF)   (Smart Trail / Trend Cloud / Reversal Zones)
//  10. Market-regime classifier              (Trend / Range / Breakout / Reversal)
//  11. POI ranking                            (nearest demand/supply zone vs bias)
//  12. Multi-symbol scanner                   (bias + RSI for up to 5 symbols)
//   +  Kalman trend filter (extra confluence), A+/A/B confidence grade,
//      Buy/Sell + STRONG signals, no-repaint commit, alert routing,
//      and a compact on-chart dashboard.
//
// NO-REPAINT: with "Lock signals at candle close" ON (default), every signal is
// committed only on the confirmed candle — historical = what you'd see live.
// The backtest is an indicator-side SIMULATION (half at TP1, half to TP2); it is
// an estimate for tuning, not a broker-accurate strategy fill model.
//
// This completes the v1–v4 roadmap. Further ideas: ML-assisted parameter
// optimisation (off-platform), volume-profile / cumulative-delta integration.
// =============================================================================

indicator("Project SENTINEL — Elite v4", "SENTINEL", overlay = true, max_lines_count = 500, max_boxes_count = 500, max_labels_count = 500)

// =============================================================================
// INPUTS
// =============================================================================

// --- Higher-Timeframe Bias -----------------------------------------------------
grpBias   = "1 · Higher-Timeframe Bias"
biasLen   = input.int(120, "Bias EMA length",            minval = 2,  group = grpBias, tooltip = "Each HTF is bullish when its close is above this EMA, bearish when below.")
tf1       = input.timeframe("W",   "HTF 1",              group = grpBias)
tf2       = input.timeframe("D",   "HTF 2",              group = grpBias)
tf3       = input.timeframe("120", "HTF 3",              group = grpBias)
showBiasBG= input.bool(false, "Tint background with net bias", group = grpBias)

// --- Market Structure ----------------------------------------------------------
grpStruct = "2 · Market Structure"
pivotLen  = input.int(10, "Swing pivot length", minval = 1, group = grpStruct, tooltip = "Bars on each side required to confirm a swing high/low. Larger = fewer, stronger swings.")
showBOS   = input.bool(true,  "Show BOS / CHOCH labels", group = grpStruct)

// --- Fair Value Gaps -----------------------------------------------------------
grpFVG    = "3 · Fair Value Gaps"
showFVG   = input.bool(true, "Show FVGs",                group = grpFVG)
fvgMax    = input.int(6, "Max FVGs kept per side", minval = 1, maxval = 50, group = grpFVG)
fvgDelete = input.bool(true, "Delete FVG once fully mitigated", group = grpFVG)
colBullFVG= input.color(color.new(color.teal,   80), "Bullish FVG", group = grpFVG, inline = "fvgcol")
colBearFVG= input.color(color.new(color.maroon, 80), "Bearish FVG", group = grpFVG, inline = "fvgcol")

// --- Liquidity -----------------------------------------------------------------
grpLiq    = "4 · Liquidity"
showSweep = input.bool(true, "Show liquidity sweeps", group = grpLiq, tooltip = "A sweep = wick takes out a prior swing then closes back inside (stop-hunt).")

// --- Sessions ------------------------------------------------------------------
grpSess   = "5 · Sessions"
sessTZ    = input.string("America/New_York", "Session timezone", group = grpSess, tooltip = "ICT kill zones are normally defined in New York time.")
showKZ    = input.bool(true, "Highlight kill zones", group = grpSess)
asianSess = input.session("2000-0000", "Asian range",     group = grpSess)
lonSess   = input.session("0200-0500", "London kill zone",group = grpSess)
nySess    = input.session("0830-1100", "New York kill zone", group = grpSess)
showLevels= input.bool(true, "Show PDH/PDL & PWH/PWL", group = grpSess)

// --- Confirmation filters ------------------------------------------------------
grpFilt   = "6 · Confirmation Filters"
enableMom = input.bool(true, "Enable momentum (RSI) filter", group = grpFilt, tooltip = "Adds a confluence point when RSI agrees with the trade direction. Keep ON.")
momLen    = input.int(20, "RSI length", minval = 2, group = grpFilt)
momThresh = input.int(50, "RSI bull/bear threshold", minval = 1, maxval = 99, group = grpFilt, tooltip = "Bull when RSI > threshold, bear when RSI < (100 - threshold). 50 = simple midline.")
enableVol = input.bool(true, "Enable volume filter", group = grpFilt, tooltip = "Adds a confluence point when volume exceeds its average (participation). Keep ON.")
volLen    = input.int(22, "Volume average length", minval = 2, group = grpFilt)
volMult   = input.float(1.0, "Volume multiple", minval = 0.1, step = 0.1, group = grpFilt)

// --- Signals & Alerts ----------------------------------------------------------
grpConf   = "7 · Signals & Alerts"
dirMode   = input.string("Both", "Trade direction", options = ["Both","Long only","Short only"], group = grpConf, tooltip = "Filter signals by side. Use to suppress one direction on instruments with a structural drift (e.g. indices).")
minConf   = input.int(4, "Min confluence — long (normal)", minval = 1, maxval = 9, group = grpConf, tooltip = "Confluences required to fire a normal LONG signal.")
minConfS  = input.int(5, "Min confluence — short (normal)", minval = 1, maxval = 9, group = grpConf, tooltip = "Confluences required to fire a normal SHORT signal. Raise this independently to cut weak shorts.")
strongConf= input.int(5, "Min confluence (STRONG signal)", minval = 1, maxval = 9, group = grpConf, tooltip = "Confluences required to upgrade a signal to Strong (higher conviction).")
confirmClose = input.bool(true, "Lock signals at candle close (no repaint)", group = grpConf, tooltip = "When ON, signals/alerts only commit on the closed candle — what you see historically is what you'd have seen live.")
alertMode = input.string("All", "Alert on", options = ["All","Buy only","Sell only","Strong only"], group = grpConf)
showSig   = input.bool(true, "Plot signal markers", group = grpConf)

// --- Trade Manager & Backtest --------------------------------------------------
grpTM     = "8 · Trade Manager & Backtest"
enableTM  = input.bool(true,  "Enable trade manager + backtest", group = grpTM)
showTrades= input.bool(true,  "Draw entry / SL / TP zones", group = grpTM)
slLook    = input.int(10, "Stop-loss S/R lookback (bars)", minval = 1, group = grpTM, tooltip = "Candles scanned for the recent swing used as the stop.")
atrLenTM  = input.int(4, "ATR length (stop buffer)", minval = 1, group = grpTM)
bufMult   = input.float(1.3, "Stop buffer (ATR multiple)", minval = 0.0, step = 0.1, group = grpTM, tooltip = "Extra padding beyond the swing, as a multiple of ATR (wick protection).")
rr1       = input.float(1.0, "TP1 (R multiple)", minval = 0.1, step = 0.1, group = grpTM)
rr2       = input.float(3.0, "TP2 (R multiple)", minval = 0.1, step = 0.1, group = grpTM)
arrowExit = input.bool(true,  "Arrow-Way exit on opposite signal", group = grpTM, tooltip = "Close the active trade early when an opposite signal fires.")
keepTrades= input.int(15, "Trade drawings to keep", minval = 1, maxval = 100, group = grpTM)
showBT    = input.bool(true,  "Show backtest table", group = grpTM)
btPos     = input.string("Bottom Left", "Backtest table position", options = ["Bottom Left","Bottom Right","Top Left","Top Right","Middle Left"], group = grpTM)

// --- Dashboard -----------------------------------------------------------------
grpDash   = "9 · Dashboard"
showDash  = input.bool(true, "Show dashboard", group = grpDash)
dashPos   = input.string("Top Right", "Position", options = ["Top Right","Top Left","Bottom Right","Bottom Left","Middle Right"], group = grpDash)

// --- Order Blocks --------------------------------------------------------------
grpOB     = "10 · Order Blocks"
showOB    = input.bool(true, "Show order blocks", group = grpOB)
obSearch  = input.int(15, "OB search lookback (bars)", minval = 1, group = grpOB, tooltip = "Bars scanned back from a structure break to find the originating candle.")
obMax     = input.int(5, "Max order blocks per side", minval = 1, maxval = 30, group = grpOB)
obDelete  = input.bool(false, "Delete OB when broken (else mark as breaker)", group = grpOB)
colBullOB = input.color(color.new(color.green, 80), "Bullish OB (demand)", group = grpOB, inline = "obc")
colBearOB = input.color(color.new(color.red,   80), "Bearish OB (supply)", group = grpOB, inline = "obc")

// --- Overlays (visual only) ----------------------------------------------------
grpOv     = "11 · Overlays (visual only)"
showTrail = input.bool(false, "Smart Trail", group = grpOv, tooltip = "ATR trailing stop that flips with trend.")
trailLen  = input.int(10, "Smart Trail ATR length", minval = 1, group = grpOv)
trailMult = input.float(3.0, "Smart Trail ATR multiple", minval = 0.1, step = 0.1, group = grpOv)
showCloud = input.bool(false, "Trend Cloud", group = grpOv, tooltip = "Fast vs slow EMA fill showing trend direction.")
tcFast    = input.int(20, "Cloud fast EMA", minval = 1, group = grpOv)
tcSlow    = input.int(50, "Cloud slow EMA", minval = 1, group = grpOv)
showRZ    = input.bool(true, "Reversal Zones", group = grpOv, tooltip = "VWMA +/- deviation bands marking statistically stretched price.")
rzLen     = input.int(20, "Reversal Zone length", minval = 1, group = grpOv)
rzMult    = input.float(2.0, "Reversal Zone deviation", minval = 0.1, step = 0.1, group = grpOv)

// --- Elite (v4) ----------------------------------------------------------------
grpV4       = "12 · Elite"
enableKalman= input.bool(true,  "Kalman trend as a confluence", group = grpV4, tooltip = "Adds a confluence point when the Kalman-filtered price is rising (long) / falling (short).")
showKalman  = input.bool(false, "Plot Kalman trend line", group = grpV4)
kQ          = input.float(0.01, "Kalman process noise (adaptivity)", minval = 0.0001, step = 0.001, group = grpV4, tooltip = "Higher = follows price faster, less smoothing.")
kR          = input.float(0.10, "Kalman measurement noise (smoothing)", minval = 0.001, step = 0.01, group = grpV4, tooltip = "Higher = smoother, more lag.")
showRegime  = input.bool(true,  "Show market regime", group = grpV4)
adxLen      = input.int(14, "ADX length", minval = 1, group = grpV4)
adxTrend    = input.float(22.0, "ADX trend threshold", minval = 1, group = grpV4)
showPOI     = input.bool(true,  "Show nearest POI in dashboard", group = grpV4)
showScanner = input.bool(false, "Show multi-symbol scanner", group = grpV4, tooltip = "Bias + RSI for up to 5 symbols on the scanner timeframe.")
scanTF      = input.timeframe("60", "Scanner timeframe", group = grpV4)
sym1        = input.symbol("OANDA:XAUUSD",     "Scanner symbol 1", group = grpV4)
sym2        = input.symbol("OANDA:EURUSD",     "Scanner symbol 2", group = grpV4)
sym3        = input.symbol("BINANCE:BTCUSDT",  "Scanner symbol 3", group = grpV4)
sym4        = input.symbol("",                 "Scanner symbol 4", group = grpV4)
sym5        = input.symbol("",                 "Scanner symbol 5", group = grpV4)

// =============================================================================
// MODULE 1 — HIGHER-TIMEFRAME BIAS
// =============================================================================
// Each HTF returns +1 (bullish), -1 (bearish), 0 (flat) from price vs an EMA.

f_tfBias(_tf, _len) =>
    [c, e] = request.security(syminfo.tickerid, _tf, [close, ta.ema(close, _len)], lookahead = barmerge.lookahead_off, gaps = barmerge.gaps_off)
    c > e ? 1 : c < e ? -1 : 0

bias1 = f_tfBias(tf1, biasLen)
bias2 = f_tfBias(tf2, biasLen)
bias3 = f_tfBias(tf3, biasLen)
biasNet = bias1 + bias2 + bias3            // range -3 .. +3
biasBull = biasNet > 0
biasBear = biasNet < 0

// =============================================================================
// MODULE 2 — MARKET STRUCTURE (swing pivots -> BOS / CHOCH)
// =============================================================================
ph = ta.pivothigh(high, pivotLen, pivotLen)
pl = ta.pivotlow(low,  pivotLen, pivotLen)

var float lastSwingHigh = na
var float lastSwingLow  = na
if not na(ph)
    lastSwingHigh := ph
if not na(pl)
    lastSwingLow := pl

var int trend = 0                          // +1 up, -1 down
bosUp    = not na(lastSwingHigh) and close > lastSwingHigh and close[1] <= lastSwingHigh
bosDown  = not na(lastSwingLow)  and close < lastSwingLow  and close[1] >= lastSwingLow

bosUpEvt = false
bosDnEvt = false
chochUp  = false
chochDn  = false
if bosUp
    if trend == -1
        chochUp := true
    else
        bosUpEvt := true
    trend := 1
if bosDown
    if trend == 1
        chochDn := true
    else
        bosDnEvt := true
    trend := -1

if showBOS
    if bosUpEvt
        label.new(bar_index, low,  "BOS",   color = color.new(color.green, 30), style = label.style_label_up,   textcolor = color.white, size = size.tiny)
    if bosDnEvt
        label.new(bar_index, high, "BOS",   color = color.new(color.red,   30), style = label.style_label_down, textcolor = color.white, size = size.tiny)
    if chochUp
        label.new(bar_index, low,  "CHoCH", color = color.new(color.lime,  10), style = label.style_label_up,   textcolor = color.black, size = size.tiny)
    if chochDn
        label.new(bar_index, high, "CHoCH", color = color.new(color.orange,10), style = label.style_label_down, textcolor = color.black, size = size.tiny)

// =============================================================================
// MODULE 3 — FAIR VALUE GAPS
// =============================================================================
// Bullish FVG: low[0] > high[2]   (gap between high[2] and low[0])
// Bearish FVG: high[0] < low[2]    (gap between high[0] and low[2])
bullFVG = low > high[2]
bearFVG = high < low[2]

var array<box> bullBoxes = array.new<box>()
var array<box> bearBoxes = array.new<box>()

if showFVG and barstate.isconfirmed
    if bullFVG
        b = box.new(bar_index - 2, low, bar_index + 3, high[2], border_color = color.new(color.teal, 40), bgcolor = colBullFVG)
        array.push(bullBoxes, b)
        if array.size(bullBoxes) > fvgMax
            box.delete(array.shift(bullBoxes))
    if bearFVG
        b = box.new(bar_index - 2, low[2], bar_index + 3, high, border_color = color.new(color.maroon, 40), bgcolor = colBearFVG)
        array.push(bearBoxes, b)
        if array.size(bearBoxes) > fvgMax
            box.delete(array.shift(bearBoxes))

// Maintain boxes: extend right edge + handle mitigation lifecycle.
f_manageFVG(boxes, isBull) =>
    if array.size(boxes) > 0
        for i = array.size(boxes) - 1 to 0
            b = array.get(boxes, i)
            box.set_right(b, bar_index + 3)
            top = box.get_top(b)
            bot = box.get_bottom(b)
            consumed = isBull ? (low <= bot) : (high >= top)
            if consumed
                if fvgDelete
                    // remove from array first, then delete the drawing so this
                    // branch ends on a void call (matches the else branch type).
                    array.remove(boxes, i)
                    box.delete(b)
                else
                    box.set_bgcolor(b, color.new(color.gray, 88))
                    box.set_border_color(b, color.new(color.gray, 70))

if showFVG
    f_manageFVG(bullBoxes, true)
    f_manageFVG(bearBoxes, false)

// Confluence flag: is price currently interacting with a live FVG zone?
// (a bar overlaps a box when its range crosses the box's top/bottom)
f_priceInZone(boxes) =>
    bool hit = false
    if array.size(boxes) > 0
        for i = 0 to array.size(boxes) - 1
            b = array.get(boxes, i)
            if low <= box.get_top(b) and high >= box.get_bottom(b)
                hit := true
    hit

bullFVGtap = f_priceInZone(bullBoxes)
bearFVGtap = f_priceInZone(bearBoxes)

// =============================================================================
// MODULE 4 — LIQUIDITY SWEEPS / STOP-HUNTS
// =============================================================================
// Sweep of lows  (bullish): wick takes out prior swing low, closes back above.
// Sweep of highs (bearish): wick takes out prior swing high, closes back below.
// Detection is independent of the display toggle so confluence still counts it.
sweepLowRaw  = not na(lastSwingLow)  and low  < lastSwingLow  and close > lastSwingLow
sweepHighRaw = not na(lastSwingHigh) and high > lastSwingHigh and close < lastSwingHigh
// Fire once per fresh sweep (don't repeat while the wick stays beyond the swing).
sweepLow  = sweepLowRaw  and not sweepLowRaw[1]
sweepHigh = sweepHighRaw and not sweepHighRaw[1]

if showSweep and sweepLow
    label.new(bar_index, low,  "✦ swept", yloc = yloc.belowbar, color = color.new(color.aqua, 20), style = label.style_label_up,   textcolor = color.black, size = size.tiny)
if showSweep and sweepHigh
    label.new(bar_index, high, "✦ swept", yloc = yloc.abovebar, color = color.new(color.fuchsia, 20), style = label.style_label_down, textcolor = color.white, size = size.tiny)

// =============================================================================
// MODULE 5 — SESSION INTELLIGENCE + KEY LEVELS
// =============================================================================
f_inSess(_sess) => not na(time(timeframe.period, _sess, sessTZ))

inAsian  = f_inSess(asianSess)
inLondon = f_inSess(lonSess)
inNY     = f_inSess(nySess)
inKillZone = inLondon or inNY

// NOTE: bgcolor() must live in global scope, so conditions are inlined.
bgcolor(showKZ and inLondon ? color.new(color.blue,   92) : na, title = "London KZ")
bgcolor(showKZ and inNY     ? color.new(color.orange, 92) : na, title = "New York KZ")
bgcolor(showKZ and inAsian  ? color.new(color.gray,   94) : na, title = "Asian range")
bgcolor(showBiasBG and biasBull ? color.new(color.green, 95) : showBiasBG and biasBear ? color.new(color.red, 95) : na, title = "Net HTF bias")

// Previous-day / previous-week liquidity (lookahead_on with [1] = safe, no repaint)
[pdh, pdl] = request.security(syminfo.tickerid, "D", [high[1], low[1]], lookahead = barmerge.lookahead_on)
[pwh, pwl] = request.security(syminfo.tickerid, "W", [high[1], low[1]], lookahead = barmerge.lookahead_on)

plot(showLevels ? pdh : na, "PDH", color = color.new(color.red,   0), style = plot.style_linebr, linewidth = 1)
plot(showLevels ? pdl : na, "PDL", color = color.new(color.green, 0), style = plot.style_linebr, linewidth = 1)
plot(showLevels ? pwh : na, "PWH", color = color.new(color.red,   40), style = plot.style_linebr, linewidth = 2)
plot(showLevels ? pwl : na, "PWL", color = color.new(color.green, 40), style = plot.style_linebr, linewidth = 2)

// =============================================================================
// CONFIRMATION FILTERS (momentum + volume)
// =============================================================================
rsiVal   = ta.rsi(close, momLen)
momBull  = rsiVal > momThresh
momBear  = rsiVal < (100 - momThresh)
volAvg   = ta.sma(volume, volLen)
volSpike = volume > volAvg * volMult

// Kalman trend filter (1-D Kalman on price). kBull when the estimate is rising.
f_kalman(src, q, r) =>
    var float x = na
    var float p = 1.0
    x1 = na(x[1]) ? src : x[1]
    p1 = na(p[1]) ? 1.0 : p[1] + q
    kg = p1 / (p1 + r)
    x := x1 + kg * (src - x1)
    p := (1 - kg) * p1
    x
kVal  = f_kalman(close, kQ, kR)
kBull = kVal > kVal[1]
kBear = kVal < kVal[1]
plot(showKalman ? kVal : na, "Kalman trend", color = kBull ? color.new(color.aqua, 0) : color.new(color.orange, 0), linewidth = 2)

// =============================================================================
// MODULE 6 — CONFLUENCE SCORING, SIGNALS & ALERTS
// =============================================================================
// Base 5 confluences (HTF bias, structure, sweep, FVG tap, kill zone) plus the
// optional momentum, volume and Kalman filters. Max scales with which are on.
maxConf = 5 + (enableMom ? 1 : 0) + (enableVol ? 1 : 0) + (enableKalman ? 1 : 0)

longConf  = (biasBull ? 1 : 0) + (trend == 1 ? 1 : 0)  + (sweepLow ? 1 : 0)  + (bullFVGtap ? 1 : 0) + (inKillZone ? 1 : 0) + (enableMom and momBull ? 1 : 0) + (enableVol and volSpike ? 1 : 0) + (enableKalman and kBull ? 1 : 0)
shortConf = (biasBear ? 1 : 0) + (trend == -1 ? 1 : 0) + (sweepHigh ? 1 : 0) + (bearFVGtap ? 1 : 0) + (inKillZone ? 1 : 0) + (enableMom and momBear ? 1 : 0) + (enableVol and volSpike ? 1 : 0) + (enableKalman and kBear ? 1 : 0)

// No-repaint: only commit on the confirmed candle when confirmClose is ON.
commit = not confirmClose or barstate.isconfirmed

allowLong  = dirMode != "Short only"
allowShort = dirMode != "Long only"
longSignal  = allowLong  and sweepLow  and longConf  >= minConf  and commit
shortSignal = allowShort and sweepHigh and shortConf >= minConfS and commit
longStrong  = longSignal  and longConf  >= strongConf
shortStrong = shortSignal and shortConf >= strongConf
longNormal  = longSignal  and not longStrong
shortNormal = shortSignal and not shortStrong

// Clean, SPECTRA-style markers: tiny triangles for normal signals, compact
// BUY+/SELL+ pills for strong ones (much less chart clutter than big text).
plotshape(showSig and longNormal,  title = "Buy",  style = shape.triangleup,   location = location.belowbar, color = color.new(color.green, 0), size = size.tiny)
plotshape(showSig and shortNormal, title = "Sell", style = shape.triangledown, location = location.abovebar, color = color.new(color.red,   0), size = size.tiny)
if showSig and longStrong
    label.new(bar_index, low,  "BUY+",  yloc = yloc.belowbar, style = label.style_label_up,   color = color.new(color.lime, 0), textcolor = color.black, size = size.small)
if showSig and shortStrong
    label.new(bar_index, high, "SELL+", yloc = yloc.abovebar, style = label.style_label_down, color = color.new(color.red,  0), textcolor = color.white, size = size.small)

// Alert routing
allowBuy  = alertMode == "All" or alertMode == "Buy only"
allowSell = alertMode == "All" or alertMode == "Sell only"
buyAlert  = longSignal  and (alertMode == "Strong only" ? longStrong  : allowBuy)
sellAlert = shortSignal and (alertMode == "Strong only" ? shortStrong : allowSell)

if buyAlert
    alert("SENTINEL " + (longStrong ? "STRONG BUY" : "BUY") + "  |  " + syminfo.ticker + "  |  confluence " + str.tostring(longConf) + "/" + str.tostring(maxConf) + "  |  price " + str.tostring(close), alert.freq_once_per_bar)
if sellAlert
    alert("SENTINEL " + (shortStrong ? "STRONG SELL" : "SELL") + "  |  " + syminfo.ticker + "  |  confluence " + str.tostring(shortConf) + "/" + str.tostring(maxConf) + "  |  price " + str.tostring(close), alert.freq_once_per_bar)

// Template alertcondition()s (for users who prefer the alert dialog dropdown)
alertcondition(longSignal,  "SENTINEL Buy",  "SENTINEL buy setup confirmed")
alertcondition(shortSignal, "SENTINEL Sell", "SENTINEL sell setup confirmed")
alertcondition(longStrong or shortStrong, "SENTINEL Strong only", "SENTINEL strong setup confirmed")
alertcondition(sweepLow or sweepHigh, "SENTINEL Liquidity Sweep", "Liquidity sweep detected")

// =============================================================================
// MODULE 7 — TRADE MANAGER + BACKTEST
// =============================================================================
// Virtual one-trade-at-a-time engine. On a confirmed signal it sets entry, a
// stop (recent S/R lookback +/- ATR buffer) and TP1/TP2 (R multiples), then
// tracks the result bar-by-bar with half-and-half management (1/2 at TP1,
// 1/2 runs to TP2). Outcomes feed the backtest table. This is an indicator-side
// SIMULATION — it never places orders.

// Stat stores. Category index: 0=BUY 1=Strong BUY 2=SELL 3=Strong SELL
var array<int>   catWins = array.from(0, 0, 0, 0)
var array<int>   catLoss = array.from(0, 0, 0, 0)
var array<float> catGP   = array.from(0.0, 0.0, 0.0, 0.0)   // gross profit
var array<float> catGL   = array.from(0.0, 0.0, 0.0, 0.0)   // gross loss (stored +)
// Outcome index: 0=TP1+TP2 1=TP1+SL 2=SL 3=Exit/BE
var array<int>   outCnt  = array.from(0, 0, 0, 0)
var array<float> outPL   = array.from(0.0, 0.0, 0.0, 0.0)

f_record(catIdx, outIdx, pl) =>
    if pl >= 0
        array.set(catWins, catIdx, array.get(catWins, catIdx) + 1)
        array.set(catGP,   catIdx, array.get(catGP, catIdx) + pl)
    else
        array.set(catLoss, catIdx, array.get(catLoss, catIdx) + 1)
        array.set(catGL,   catIdx, array.get(catGL, catIdx) - pl)
    array.set(outCnt, outIdx, array.get(outCnt, outIdx) + 1)
    array.set(outPL,  outIdx, array.get(outPL,  outIdx) + pl)

// Active-trade state
var bool  inTrade = false
var int   tDir    = 0
var int   tCat    = 0
var float tEntry  = na
var float tStop   = na
var float tTp1    = na
var float tTp2    = na
var bool  tTp1Hit = false
var bool  tDrawn  = false
var box   aSL     = na
var box   aTP     = na
var line  aTP1    = na
var array<box>  drawBoxes = array.new<box>()
var array<line> drawLines = array.new<line>()

// ta.* must run every bar (not inside conditionals) for stable history
atrValTM = ta.atr(atrLenTM)
lowestN  = ta.lowest(low,  slLook)
highestN = ta.highest(high, slLook)

bool exitMark = false

if enableTM and barstate.isconfirmed
    // 1) manage the active trade against this closed candle
    if inTrade
        bool closed = false
        if tDir == 1
            if low <= tStop
                if tTp1Hit
                    f_record(tCat, 1, 0.5 * (tTp1 - tEntry) + 0.5 * (tStop - tEntry))
                else
                    f_record(tCat, 2, tStop - tEntry)
                closed := true
            else
                if not tTp1Hit and high >= tTp1
                    tTp1Hit := true
                if tTp1Hit and high >= tTp2
                    f_record(tCat, 0, 0.5 * (tTp1 - tEntry) + 0.5 * (tTp2 - tEntry))
                    closed := true
        else
            if high >= tStop
                if tTp1Hit
                    f_record(tCat, 1, 0.5 * (tEntry - tTp1) + 0.5 * (tEntry - tStop))
                else
                    f_record(tCat, 2, tEntry - tStop)
                closed := true
            else
                if not tTp1Hit and low <= tTp1
                    tTp1Hit := true
                if tTp1Hit and low <= tTp2
                    f_record(tCat, 0, 0.5 * (tEntry - tTp1) + 0.5 * (tEntry - tTp2))
                    closed := true
        if closed
            inTrade := false

    // 2) Arrow-Way early exit when an opposite signal fires
    if inTrade and arrowExit and ((tDir == 1 and shortSignal) or (tDir == -1 and longSignal))
        plE = tDir == 1 ? (tTp1Hit ? 0.5 * (tTp1 - tEntry) + 0.5 * (close - tEntry) : close - tEntry) : (tTp1Hit ? 0.5 * (tEntry - tTp1) + 0.5 * (tEntry - close) : tEntry - close)
        f_record(tCat, 3, plE)
        inTrade := false
        exitMark := true

    // 3) open a new trade if flat and a signal fires
    if not inTrade and (longSignal or shortSignal)
        dir = longSignal ? 1 : -1
        strong = longSignal ? longStrong : shortStrong
        buf = atrValTM * bufMult
        rawStop = dir == 1 ? lowestN : highestN
        entry = close
        stop = dir == 1 ? rawStop - buf : rawStop + buf
        r = math.abs(entry - stop)
        if r > 0
            inTrade := true
            tDir := dir
            tCat := dir == 1 ? (strong ? 1 : 0) : (strong ? 3 : 2)
            tEntry := entry
            tStop := stop
            tTp1 := dir == 1 ? entry + r * rr1 : entry - r * rr1
            tTp2 := dir == 1 ? entry + r * rr2 : entry - r * rr2
            tTp1Hit := false
            tDrawn := false
            if showTrades
                aSL := box.new(bar_index, math.max(entry, stop), bar_index, math.min(entry, stop), bgcolor = color.new(color.red, 88), border_color = color.new(color.red, 65))
                aTP := box.new(bar_index, math.max(entry, tTp2), bar_index, math.min(entry, tTp2), bgcolor = color.new(color.green, 90), border_color = color.new(color.green, 65))
                aTP1 := line.new(bar_index, tTp1, bar_index, tTp1, color = color.new(color.yellow, 0), style = line.style_dashed)
                array.push(drawBoxes, aSL)
                array.push(drawBoxes, aTP)
                array.push(drawLines, aTP1)
                tDrawn := true
                if array.size(drawBoxes) > keepTrades * 2
                    box.delete(array.shift(drawBoxes))
                    box.delete(array.shift(drawBoxes))
                if array.size(drawLines) > keepTrades
                    line.delete(array.shift(drawLines))

    // 4) extend the active trade's drawings to the current bar
    if inTrade and tDrawn
        box.set_right(aSL, bar_index)
        box.set_right(aTP, bar_index)
        line.set_x2(aTP1, bar_index)

plotshape(showTrades and exitMark, title = "Smart Exit", style = shape.xcross, location = location.abovebar, color = color.new(color.yellow, 0), size = size.tiny, text = "exit")

// --- Backtest table -----------------------------------------------------------
f_btPos() =>
    switch btPos
        "Bottom Left"  => position.bottom_left
        "Bottom Right" => position.bottom_right
        "Top Left"     => position.top_left
        "Top Right"    => position.top_right
        "Middle Left"  => position.middle_left
        => position.bottom_left

f_pf(gp, gl) => gl == 0 ? (gp == 0 ? "—" : "inf") : str.tostring(gp / gl, "#.##")
f_wr(w, l)   => (w + l) == 0 ? "—" : str.tostring(100.0 * w / (w + l), "#.#") + "%"
f_pl(net)    => (net >= 0 ? "+" : "") + str.tostring(net, "#.###")
f_wl(w, l)   => str.tostring(w) + " / " + str.tostring(l)

f_btRow(t, r, dotCol, name, nameCol, w, l, gp, gl, bgc) =>
    table.cell(t, 0, r, "●", bgcolor = bgc, text_color = dotCol, text_size = size.tiny)
    table.cell(t, 1, r, name, bgcolor = bgc, text_color = nameCol, text_size = size.tiny)
    table.cell(t, 2, r, f_wl(w, l), bgcolor = bgc, text_color = color.new(color.white, 0), text_size = size.tiny)
    table.cell(t, 3, r, f_wr(w, l), bgcolor = bgc, text_color = color.new(color.white, 0), text_size = size.tiny)
    table.cell(t, 4, r, f_pl(gp - gl), bgcolor = bgc, text_color = (gp - gl) >= 0 ? color.new(color.green, 0) : color.new(color.red, 0), text_size = size.tiny)
    table.cell(t, 5, r, f_pf(gp, gl), bgcolor = bgc, text_color = color.new(color.white, 0), text_size = size.tiny)

f_btOut(t, r, name, cnt, pl, bgc) =>
    table.cell(t, 0, r, "", bgcolor = bgc, text_size = size.tiny)
    table.cell(t, 1, r, name, bgcolor = bgc, text_color = color.new(color.white, 0), text_size = size.tiny)
    table.cell(t, 2, r, str.tostring(cnt), bgcolor = bgc, text_color = color.new(color.white, 0), text_size = size.tiny)
    table.cell(t, 3, r, "", bgcolor = bgc, text_size = size.tiny)
    table.cell(t, 4, r, f_pl(pl), bgcolor = bgc, text_color = pl >= 0 ? color.new(color.green, 0) : color.new(color.red, 0), text_size = size.tiny)
    table.cell(t, 5, r, "", bgcolor = bgc, text_size = size.tiny)

var table bt = na
if showBT and enableTM
    if na(bt)
        bt := table.new(f_btPos(), 6, 13, border_width = 1, frame_width = 1, frame_color = color.new(color.gray, 50))
    if barstate.islast
        allBuyW  = array.get(catWins, 0) + array.get(catWins, 1)
        allBuyL  = array.get(catLoss, 0) + array.get(catLoss, 1)
        allBuyGP = array.get(catGP, 0)   + array.get(catGP, 1)
        allBuyGL = array.get(catGL, 0)   + array.get(catGL, 1)
        allSellW  = array.get(catWins, 2) + array.get(catWins, 3)
        allSellL  = array.get(catLoss, 2) + array.get(catLoss, 3)
        allSellGP = array.get(catGP, 2)   + array.get(catGP, 3)
        allSellGL = array.get(catGL, 2)   + array.get(catGL, 3)
        ovW  = allBuyW + allSellW
        ovL  = allBuyL + allSellL
        ovGP = allBuyGP + allSellGP
        ovGL = allBuyGL + allSellGL
        total = ovW + ovL

        cHd  = color.new(#0b2a4a, 0)
        cOut = color.new(#3a1f4a, 0)
        bgc  = color.new(#11151c, 0)
        wht  = color.new(color.white, 0)

        table.cell(bt, 0, 0, "BT",       bgcolor = cHd, text_color = color.new(color.orange, 0), text_size = size.tiny)
        table.cell(bt, 1, 0, "½TP1+½TP2",bgcolor = cHd, text_color = wht, text_size = size.tiny)
        table.cell(bt, 2, 0, "W / L",    bgcolor = cHd, text_color = wht, text_size = size.tiny)
        table.cell(bt, 3, 0, "WR%",      bgcolor = cHd, text_color = wht, text_size = size.tiny)
        table.cell(bt, 4, 0, "P/L",      bgcolor = cHd, text_color = wht, text_size = size.tiny)
        table.cell(bt, 5, 0, "PF",       bgcolor = cHd, text_color = wht, text_size = size.tiny)

        f_btRow(bt, 1, color.new(color.aqua, 0),  "OVERALL " + str.tostring(total), wht, ovW, ovL, ovGP, ovGL, bgc)
        f_btRow(bt, 2, color.new(color.green, 0), "▲ All BUY",     color.new(color.green, 0), allBuyW, allBuyL, allBuyGP, allBuyGL, bgc)
        f_btRow(bt, 3, color.new(color.green, 40),"  BUY",         color.new(color.gray, 0), array.get(catWins,0), array.get(catLoss,0), array.get(catGP,0), array.get(catGL,0), bgc)
        f_btRow(bt, 4, color.new(color.green, 40),"  Strong BUY",  color.new(color.gray, 0), array.get(catWins,1), array.get(catLoss,1), array.get(catGP,1), array.get(catGL,1), bgc)
        f_btRow(bt, 5, color.new(color.red, 0),   "▼ All SELL",    color.new(color.red, 0), allSellW, allSellL, allSellGP, allSellGL, bgc)
        f_btRow(bt, 6, color.new(color.red, 40),  "  SELL",        color.new(color.gray, 0), array.get(catWins,2), array.get(catLoss,2), array.get(catGP,2), array.get(catGL,2), bgc)
        f_btRow(bt, 7, color.new(color.red, 40),  "  Strong SELL", color.new(color.gray, 0), array.get(catWins,3), array.get(catLoss,3), array.get(catGP,3), array.get(catGL,3), bgc)

        table.cell(bt, 0, 8, "",         bgcolor = cOut, text_size = size.tiny)
        table.cell(bt, 1, 8, "OUTCOMES", bgcolor = cOut, text_color = wht, text_size = size.tiny)
        table.cell(bt, 2, 8, "Count",    bgcolor = cOut, text_color = wht, text_size = size.tiny)
        table.cell(bt, 3, 8, "",         bgcolor = cOut, text_size = size.tiny)
        table.cell(bt, 4, 8, "P/L",      bgcolor = cOut, text_color = wht, text_size = size.tiny)
        table.cell(bt, 5, 8, "",         bgcolor = cOut, text_size = size.tiny)

        f_btOut(bt, 9,  "TP1 + TP2", array.get(outCnt,0), array.get(outPL,0), bgc)
        f_btOut(bt, 10, "TP1 + SL",  array.get(outCnt,1), array.get(outPL,1), bgc)
        f_btOut(bt, 11, "SL",        array.get(outCnt,2), array.get(outPL,2), bgc)
        f_btOut(bt, 12, "Exit / BE", array.get(outCnt,3), array.get(outPL,3), bgc)

// =============================================================================
// MODULE 8 — ORDER BLOCKS (demand / supply, with mitigation + breakers)
// =============================================================================
// An order block is the last opposite-colour candle before a structure break:
//   bullish OB (demand)  = last bearish candle before an up break (BOS/CHoCH up)
//   bearish OB (supply)  = last bullish candle before a down break
// When price closes through an OB it is "broken" -> becomes a breaker.

f_lastOpp(searchN, wantBull) =>
    int found = na
    for k = 1 to searchN
        match = wantBull ? close[k] > open[k] : close[k] < open[k]
        if match and na(found)
            found := k
    found

var array<box> bullOB = array.new<box>()
var array<box> bearOB = array.new<box>()

bullBreak = bosUpEvt or chochUp
bearBreak = bosDnEvt or chochDn

if showOB and barstate.isconfirmed
    if bullBreak
        ko = f_lastOpp(obSearch, false)
        if not na(ko)
            ob = box.new(bar_index - ko, high[ko], bar_index + 3, low[ko], bgcolor = colBullOB, border_color = color.new(color.green, 50))
            array.push(bullOB, ob)
            if array.size(bullOB) > obMax
                box.delete(array.shift(bullOB))
    if bearBreak
        ko = f_lastOpp(obSearch, true)
        if not na(ko)
            ob = box.new(bar_index - ko, high[ko], bar_index + 3, low[ko], bgcolor = colBearOB, border_color = color.new(color.red, 50))
            array.push(bearOB, ob)
            if array.size(bearOB) > obMax
                box.delete(array.shift(bearOB))

f_manageOB(boxes, isBull) =>
    if array.size(boxes) > 0
        for i = array.size(boxes) - 1 to 0
            b = array.get(boxes, i)
            box.set_right(b, bar_index + 3)
            broken = isBull ? close < box.get_bottom(b) : close > box.get_top(b)
            if broken
                if obDelete
                    array.remove(boxes, i)
                    box.delete(b)
                else
                    box.set_bgcolor(b, color.new(color.orange, 82))
                    box.set_border_color(b, color.new(color.orange, 50))

if showOB
    f_manageOB(bullOB, true)
    f_manageOB(bearOB, false)

// =============================================================================
// MODULE 9 — OVERLAYS (visual only; default OFF)
// =============================================================================
// Smart Trail — ATR trailing stop (Supertrend-style), flips with trend.
atrTrail = ta.atr(trailLen)
upBand = hl2 - trailMult * atrTrail
dnBand = hl2 + trailMult * atrTrail
var float stUp  = na
var float stDn  = na
var int   stDir = 1
stUp := na(stUp[1]) ? upBand : (close[1] > stUp[1] ? math.max(upBand, stUp[1]) : upBand)
stDn := na(stDn[1]) ? dnBand : (close[1] < stDn[1] ? math.min(dnBand, stDn[1]) : dnBand)
stDir := stDir == -1 and close > stDn[1] ? 1 : stDir == 1 and close < stUp[1] ? -1 : stDir
trailVal = stDir == 1 ? stUp : stDn
plot(showTrail ? trailVal : na, "Smart Trail", color = stDir == 1 ? color.new(color.green, 0) : color.new(color.red, 0), linewidth = 2, style = plot.style_linebr)

// Trend Cloud — fast vs slow EMA fill.
emaFast = ta.ema(close, tcFast)
emaSlow = ta.ema(close, tcSlow)
pCloudF = plot(showCloud ? emaFast : na, "Cloud fast", color = color.new(color.blue, 50))
pCloudS = plot(showCloud ? emaSlow : na, "Cloud slow", color = color.new(color.gray, 50))
fill(pCloudF, pCloudS, color = emaFast > emaSlow ? color.new(color.green, 88) : color.new(color.red, 88), title = "Trend Cloud")

// Reversal Zones — VWMA +/- deviation bands.
rzBasis = ta.vwma(close, rzLen)
rzDev = rzMult * ta.stdev(close, rzLen)
rzUp = rzBasis + rzDev
rzLo = rzBasis - rzDev
pRzU = plot(showRZ ? rzUp : na, "Reversal upper", color = color.new(color.red, 55))
pRzL = plot(showRZ ? rzLo : na, "Reversal lower", color = color.new(color.green, 55))
fill(pRzU, pRzL, color = color.new(color.purple, 93), title = "Reversal Zone")

// =============================================================================
// MODULE 10 — MARKET-REGIME CLASSIFIER (deterministic, no ML)
// =============================================================================
[diPlus, diMinus, adxVal] = ta.dmi(adxLen, adxLen)
atrNow = ta.atr(14)
atrAvg = ta.sma(atrNow, 50)
expanding   = atrNow > atrAvg * 1.5
chochRecent = ta.barssince(chochUp or chochDn) <= 5
nearRev     = close > rzUp or close < rzLo
regime = expanding ? "Breakout" : (chochRecent or nearRev) ? "Reversal" : adxVal >= adxTrend ? "Trend" : "Range"
regimeCol = regime == "Trend" ? color.new(color.green, 0) : regime == "Breakout" ? color.new(color.aqua, 0) : regime == "Reversal" ? color.new(color.orange, 0) : color.new(color.gray, 0)

// =============================================================================
// MODULE 11 — POI RANKING (nearest zone aligned with bias)
// =============================================================================
f_nearestMid(boxes) =>
    float best = na
    float bestDist = na
    if array.size(boxes) > 0
        for i = 0 to array.size(boxes) - 1
            b = array.get(boxes, i)
            mid = (box.get_top(b) + box.get_bottom(b)) / 2
            d = math.abs(close - mid)
            if na(bestDist) or d < bestDist
                bestDist := d
                best := mid
    best
poiMid = biasBull ? f_nearestMid(bullOB) : biasBear ? f_nearestMid(bearOB) : na
poiTxt = na(poiMid) ? "—" : (biasBull ? "▲ " : "▼ ") + str.tostring(poiMid, format.mintick)

// =============================================================================
// MODULE 12 — MULTI-SYMBOL SCANNER
// =============================================================================
f_scan(sym) =>
    request.security(sym, scanTF, [close, ta.ema(close, biasLen), ta.rsi(close, momLen)], lookahead = barmerge.lookahead_off)

[c1, e1, r1] = f_scan(sym1 == "" ? syminfo.tickerid : sym1)
[c2, e2, r2] = f_scan(sym2 == "" ? syminfo.tickerid : sym2)
[c3, e3, r3] = f_scan(sym3 == "" ? syminfo.tickerid : sym3)
[c4, e4, r4] = f_scan(sym4 == "" ? syminfo.tickerid : sym4)
[c5, e5, r5] = f_scan(sym5 == "" ? syminfo.tickerid : sym5)

f_scanRow(t, r, name, c, e, rsi, bgc) =>
    bull = c > e
    table.cell(t, 0, r, name, bgcolor = bgc, text_color = color.new(color.white, 0), text_size = size.tiny)
    table.cell(t, 1, r, bull ? "▲ Bull" : "▼ Bear", bgcolor = bgc, text_color = bull ? color.new(color.green, 0) : color.new(color.red, 0), text_size = size.tiny)
    table.cell(t, 2, r, str.tostring(rsi, "#"), bgcolor = bgc, text_color = color.new(color.white, 0), text_size = size.tiny)

var table scan = na
if showScanner
    if na(scan)
        scan := table.new(position.middle_left, 3, 6, border_width = 1, frame_width = 1, frame_color = color.new(color.gray, 50))
    if barstate.islast
        sHd = color.new(#0b2a4a, 0)
        sBg = color.new(#11151c, 0)
        table.cell(scan, 0, 0, "SCANNER " + scanTF, bgcolor = sHd, text_color = color.new(color.aqua, 0), text_size = size.tiny)
        table.cell(scan, 1, 0, "Bias", bgcolor = sHd, text_color = color.new(color.white, 0), text_size = size.tiny)
        table.cell(scan, 2, 0, "RSI",  bgcolor = sHd, text_color = color.new(color.white, 0), text_size = size.tiny)
        f_scanRow(scan, 1, sym1 == "" ? "—" : sym1, c1, e1, r1, sBg)
        f_scanRow(scan, 2, sym2 == "" ? "—" : sym2, c2, e2, r2, sBg)
        f_scanRow(scan, 3, sym3 == "" ? "—" : sym3, c3, e3, r3, sBg)
        f_scanRow(scan, 4, sym4 == "" ? "—" : sym4, c4, e4, r4, sBg)
        f_scanRow(scan, 5, sym5 == "" ? "—" : sym5, c5, e5, r5, sBg)

// =============================================================================
// DASHBOARD
// =============================================================================
f_dashPos() =>
    switch dashPos
        "Top Right"     => position.top_right
        "Top Left"      => position.top_left
        "Bottom Right"  => position.bottom_right
        "Bottom Left"   => position.bottom_left
        "Middle Right"  => position.middle_right
        => position.top_right

f_biasTxt(v) => v > 0 ? "▲ Bull" : v < 0 ? "▼ Bear" : "— Flat"
f_biasCol(v) => v > 0 ? color.new(color.green, 0) : v < 0 ? color.new(color.red, 0) : color.new(color.gray, 0)

// Confidence grade from a confluence score vs its max
f_grade(conf, mx) =>
    p = mx == 0 ? 0.0 : 1.0 * conf / mx
    p >= 1.0 ? "A+" : p >= 0.85 ? "A" : p >= 0.7 ? "B" : p >= 0.5 ? "C" : "D"
f_gradeCol(g) => g == "A+" ? color.new(color.lime, 0) : g == "A" ? color.new(color.green, 0) : g == "B" ? color.new(color.yellow, 0) : g == "C" ? color.new(color.orange, 0) : color.new(color.gray, 0)

sessTxt = inLondon ? "London KZ" : inNY ? "New York KZ" : inAsian ? "Asian" : "Off-session"
sessCol = inKillZone ? color.new(color.green, 0) : color.new(color.gray, 0)

momTxt = not enableMom ? "off" : momBull ? "▲ Bull" : momBear ? "▼ Bear" : "— Flat"
momCol = not enableMom ? color.new(color.gray, 0) : f_biasCol(momBull ? 1 : momBear ? -1 : 0)
volTxt = not enableVol ? "off" : volSpike ? "High" : "Normal"
volCol = not enableVol ? color.new(color.gray, 0) : volSpike ? color.new(color.green, 0) : color.new(color.gray, 0)
sigTxt = longStrong ? "STRONG BUY" : longSignal ? "BUY" : shortStrong ? "STRONG SELL" : shortSignal ? "SELL" : "—"
sigCol = longSignal ? color.new(color.green, 0) : shortSignal ? color.new(color.red, 0) : color.new(color.gray, 0)
actConf  = math.max(longConf, shortConf)
gradeTxt = f_grade(actConf, maxConf)
kTxt = kBull ? "▲ Bull" : kBear ? "▼ Bear" : "— Flat"
kCol = f_biasCol(kBull ? 1 : kBear ? -1 : 0)

var table dash = na
if showDash
    if na(dash)
        dash := table.new(f_dashPos(), 2, 16, border_width = 1, frame_width = 1, frame_color = color.new(color.gray, 50))
    if barstate.islast
        bg = color.new(#11151c, 0)
        hd = color.new(#1f2733, 0)
        tc = color.new(color.white, 0)
        table.cell(dash, 0, 0, "PROJECT SENTINEL", bgcolor = hd, text_color = color.new(color.aqua, 0), text_size = size.small)
        table.cell(dash, 1, 0, "v4.4",             bgcolor = hd, text_color = color.new(color.gray, 0),  text_size = size.small)

        table.cell(dash, 0, 1, "HTF " + tf1, bgcolor = bg, text_color = tc, text_size = size.small)
        table.cell(dash, 1, 1, f_biasTxt(bias1), bgcolor = bg, text_color = f_biasCol(bias1), text_size = size.small)
        table.cell(dash, 0, 2, "HTF " + tf2, bgcolor = bg, text_color = tc, text_size = size.small)
        table.cell(dash, 1, 2, f_biasTxt(bias2), bgcolor = bg, text_color = f_biasCol(bias2), text_size = size.small)
        table.cell(dash, 0, 3, "HTF " + tf3, bgcolor = bg, text_color = tc, text_size = size.small)
        table.cell(dash, 1, 3, f_biasTxt(bias3), bgcolor = bg, text_color = f_biasCol(bias3), text_size = size.small)

        table.cell(dash, 0, 4, "Net bias", bgcolor = bg, text_color = tc, text_size = size.small)
        table.cell(dash, 1, 4, f_biasTxt(biasNet) + " (" + str.tostring(biasNet) + ")", bgcolor = bg, text_color = f_biasCol(biasNet), text_size = size.small)

        table.cell(dash, 0, 5, "Structure", bgcolor = bg, text_color = tc, text_size = size.small)
        table.cell(dash, 1, 5, f_biasTxt(trend), bgcolor = bg, text_color = f_biasCol(trend), text_size = size.small)

        table.cell(dash, 0, 6, "Session", bgcolor = bg, text_color = tc, text_size = size.small)
        table.cell(dash, 1, 6, sessTxt, bgcolor = bg, text_color = sessCol, text_size = size.small)

        table.cell(dash, 0, 7, "Momentum", bgcolor = bg, text_color = tc, text_size = size.small)
        table.cell(dash, 1, 7, momTxt, bgcolor = bg, text_color = momCol, text_size = size.small)

        table.cell(dash, 0, 8, "Volume", bgcolor = bg, text_color = tc, text_size = size.small)
        table.cell(dash, 1, 8, volTxt, bgcolor = bg, text_color = volCol, text_size = size.small)

        table.cell(dash, 0, 9, "Long conf", bgcolor = bg, text_color = tc, text_size = size.small)
        table.cell(dash, 1, 9, str.tostring(longConf) + "/" + str.tostring(maxConf), bgcolor = bg, text_color = longConf >= minConf ? color.new(color.green,0) : tc, text_size = size.small)

        table.cell(dash, 0, 10, "Short conf", bgcolor = bg, text_color = tc, text_size = size.small)
        table.cell(dash, 1, 10, str.tostring(shortConf) + "/" + str.tostring(maxConf), bgcolor = bg, text_color = shortConf >= minConfS ? color.new(color.red,0) : tc, text_size = size.small)

        table.cell(dash, 0, 11, "Signal", bgcolor = bg, text_color = tc, text_size = size.small)
        table.cell(dash, 1, 11, sigTxt, bgcolor = bg, text_color = sigCol, text_size = size.small)

        table.cell(dash, 0, 12, "Grade", bgcolor = bg, text_color = tc, text_size = size.small)
        table.cell(dash, 1, 12, gradeTxt + " (" + str.tostring(actConf) + "/" + str.tostring(maxConf) + ")", bgcolor = bg, text_color = f_gradeCol(gradeTxt), text_size = size.small)

        table.cell(dash, 0, 13, "Kalman", bgcolor = bg, text_color = tc, text_size = size.small)
        table.cell(dash, 1, 13, enableKalman ? kTxt : "off", bgcolor = bg, text_color = enableKalman ? kCol : color.new(color.gray, 0), text_size = size.small)

        table.cell(dash, 0, 14, "Regime", bgcolor = bg, text_color = tc, text_size = size.small)
        table.cell(dash, 1, 14, showRegime ? regime : "off", bgcolor = bg, text_color = showRegime ? regimeCol : color.new(color.gray, 0), text_size = size.small)

        table.cell(dash, 0, 15, "POI", bgcolor = bg, text_color = tc, text_size = size.small)
        table.cell(dash, 1, 15, showPOI ? poiTxt : "off", bgcolor = bg, text_color = tc, text_size = size.small)
// =============================================================================
// END OF SENTINEL
// =============================================================================
